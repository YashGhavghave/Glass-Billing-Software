{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 9002",
    "desktop:dev": "concurrently \"npm:dev\" \"wait-on tcp:9002 && cross-env ELECTRON_RENDERER_URL=http://localhost:9002 electron .\"",
    "genkit:dev": "genkit start -- node src/ai/dev.js",
    "genkit:watch": "genkit start --watch -- node src/ai/dev.js",
    "build": "next build",
    "start": "next start -p 9002",
    "start:desktop:web": "next start -p 9002",
    "desktop:start": "concurrently \"npm:start:desktop:web\" \"wait-on tcp:9002 && cross-env ELECTRON_RENDERER_URL=http://localhost:9002 electron .\"",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "1.20.0",
